# Copy this file to ".env" and fill in your real keys.
# The app reads these at runtime and shows a clear error if one is missing.

# Cohere API key - used for BOTH the embeddings and the LLM.
COHERE_API_KEY=your_cohere_key

# Pinecone API key - access to your vector database.
PINECONE_API_KEY=your_pinecone_key

# Name of the Pinecone index that prepare.py created (e.g. "kiro").
PINECONE_INDEX_NAME=kiro
